{
  "compilerOptions": {
    "noEmit": true,
    "checkJs": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "playwright-cli.js",
    "playwright-electron/**/*.js",
    "tests/**/*.ts",
    "types.d.ts"
  ]
}
